# ============================================================
# ProgreSQL — Production Environment Variables
# Copy to .env and fill in real values
# ============================================================

# --- App ---
PROGRESSQL_VERSION=1.0.47
PROGRESSQL_SERVER_PORT=8080
PROGRESSQL_ENVIRONMENT=production
PROGRESSQL_LOG_LEVEL=info

# --- Auth ---
PROGRESSQL_JWT_SECRET=your-jwt-secret-here

# --- LLM (OpenRouter) ---
PROGRESSQL_OPENROUTER_API_KEY=sk-or-v1-your-key-here
PROGRESSQL_HTTP_MODEL=qwen/qwen3-coder-next
PROGRESSQL_HTTP_BASE_URL=https://openrouter.ai/api/v1

# --- Email (SMTP) ---
PROGRESSQL_SMTP_HOST=smtp.yandex.ru
PROGRESSQL_SMTP_PORT=465
PROGRESSQL_SMTP_USER=your-email@yandex.ru
PROGRESSQL_SMTP_PASSWORD=your-smtp-password
PROGRESSQL_SMTP_FROM=your-email@yandex.ru

# --- Payments  ---
PROGRESSQL_TBANK_PASSWORD=
PROGRESSQL_TBANK_TERMINAL_KEY=
PROGRESSQL_TBANK_NOTIFICATION_URL=

# --- Database ---
PROGRESSQL_DB_USER=progressql
PROGRESSQL_DB_PASSWORD=your-db-password
PROGRESSQL_DB_NAME=progressql

# --- Grafana ---
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=your-grafana-password

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
