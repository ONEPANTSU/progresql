        "sortBy": [{ "displayName": "cost_usd", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres" },
          "rawSql": "SELECT u.email, COUNT(*) as requests, SUM(t.total_tokens) as tokens, ROUND(SUM(t.cost_usd)::numeric, 4) as cost_usd FROM token_usage t JOIN users u ON t.user_id::text = u.id::text GROUP BY u.email ORDER BY cost_usd DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    },
