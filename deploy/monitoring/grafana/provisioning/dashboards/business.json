          "datasource": { "type": "postgres", "uid": "postgres" },
          "rawSql": "SELECT COUNT(*) AS \"Pro Yearly\" FROM users WHERE plan='pro_yearly' AND plan_expires_at > NOW()",
          "format": "table",
          "refId": "A"
