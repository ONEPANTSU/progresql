    {
      "id": 13,
      "title": "LLM Cost (30d)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 34 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ef4444" },
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#ef4444", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres" },
          "rawSql": "SELECT COALESCE(SUM(cost_usd), 0) as \"LLM Cost ($)\" FROM token_usage WHERE created_at > NOW() - INTERVAL '30 days'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "Revenue (30d)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 34 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#10b981" },
          "unit": "currencyUSD",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#10b981", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
