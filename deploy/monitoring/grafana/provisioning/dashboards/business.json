        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres" },
          "rawSql": "SELECT COALESCE(SUM(amount), 0) as \"Revenue ($)\" FROM payments WHERE status = 'confirmed' AND created_at > NOW() - INTERVAL '30 days'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "title": "Profit/Loss (30d)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 34 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#ef4444", "value": null },
              { "color": "#10b981", "value": 0 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres" },
          "rawSql": "SELECT (SELECT COALESCE(SUM(amount), 0) FROM payments WHERE status = 'confirmed' AND created_at > NOW() - INTERVAL '30 days') - (SELECT COALESCE(SUM(cost_usd), 0) FROM token_usage WHERE created_at > NOW() - INTERVAL '30 days') as \"Profit/Loss ($)\"",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "title": "Top Token Users",
      "type": "table",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 34 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cost_usd" },
