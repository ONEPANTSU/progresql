          "datasource": { "type": "postgres", "uid": "postgres" },
          "rawSql": "SELECT ROUND(COUNT(DISTINCT this_week.user_id)::numeric * 100 / NULLIF(COUNT(DISTINCT last_week.user_id), 0), 1) as \"Retention %\" FROM (SELECT DISTINCT user_id FROM token_usage WHERE created_at > NOW() - INTERVAL '7 days') this_week JOIN (SELECT DISTINCT user_id FROM token_usage WHERE created_at BETWEEN NOW() - INTERVAL '14 days' AND NOW() - INTERVAL '7 days') last_week ON this_week.user_id = last_week.user_id",
