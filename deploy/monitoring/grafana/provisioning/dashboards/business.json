      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" },
        "bucketSize": 0,
        "combine": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(request_cost_usd_bucket[1h])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Top Models by Cost",
      "description": "Models ranked by total cost in USD",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cost_usd" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "cost_usd", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres" },
          "rawSql": "SELECT model, COUNT(*) as requests, SUM(total_tokens) as tokens, ROUND(SUM(cost_usd)::numeric, 4) as cost_usd FROM token_usage WHERE created_at > NOW() - INTERVAL '30 days' GROUP BY model ORDER BY cost_usd DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    },
