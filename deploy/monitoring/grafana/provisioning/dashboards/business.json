            "matcher": { "id": "byName", "options": "balance_topup" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#06b6d4" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(revenue_by_plan_total[1h])",
          "legendFormat": "{{plan}}",
          "refId": "A"
        }
      ]
    },
