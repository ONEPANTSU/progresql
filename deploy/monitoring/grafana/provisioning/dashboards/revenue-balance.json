        }
      ]
    },
    {
      "id": 11,
      "title": "Request Cost Distribution",
      "description": "Distribution of per-request costs in USD",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#8b5cf6" },
