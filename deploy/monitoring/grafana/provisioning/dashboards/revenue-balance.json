      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(balance_charged_usd_total[5m])",
          "legendFormat": "{{plan}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Total Platform Balance (USD)",
      "description": "Sum of all user balances in USD",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
