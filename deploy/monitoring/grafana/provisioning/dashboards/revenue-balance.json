{
  "id": null,
  "uid": "progressql-revenue-balance",
  "title": "ProgreSQL — Revenue, Balance & Credits",
  "description": "Prometheus-based metrics for revenue by plan, balance operations, credit usage, and active sessions",
  "tags": [
    "progressql",
    "revenue",
    "balance",
    "credits"
  ],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "#6366f1",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Revenue",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Revenue by Plan",
      "description": "Cumulative revenue broken down by plan (pro, pro_yearly, balance_topup)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 60,
            "gradientMode": "opacity",
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pro" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#8b5cf6" } }]
          },
          {
            "matcher": { "id": "byName", "options": "pro_yearly" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#6366f1" } }]
          },
          {
            "matcher": { "id": "byName", "options": "balance_topup" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#06b6d4" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(revenue_by_plan_total[1h])",
          "legendFormat": "{{plan}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Payment Totals by Status",
      "description": "Payment events by status (created, confirmed, failed)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "confirmed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }]
          },
          {
            "matcher": { "id": "byName", "options": "created" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f59e0b" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(payments_total[5m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Balance Top-ups Rate",
      "description": "Rate of balance top-up events per minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#10b981" },
          "unit": "opm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(balance_topups_total[5m]) * 60",
          "legendFormat": "Top-ups / min",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 200,
      "title": "Credits",
      "type": "row"
    },
    {
      "id": 4,
      "title": "Credits Granted vs Used vs Expired",
      "description": "Credit flow: granted to users, consumed by AI requests, and expired unused",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Granted" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Used" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#8b5cf6" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Expired" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(credits_granted_usd_total[5m]))",
          "legendFormat": "Granted",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(credits_used_usd_total[5m]))",
          "legendFormat": "Used",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(credits_expired_usd_total[5m]))",
          "legendFormat": "Expired",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "title": "Credits by Plan",
      "description": "Credit usage breakdown by plan",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "drawStyle": "bars",
