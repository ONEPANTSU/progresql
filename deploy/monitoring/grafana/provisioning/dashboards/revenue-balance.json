            "fillOpacity": 50,
            "gradientMode": "opacity",
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "free" },
